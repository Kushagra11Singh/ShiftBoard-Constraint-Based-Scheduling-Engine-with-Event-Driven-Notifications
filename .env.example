# Copy to .env and adjust values

# Scheduling Service
DATABASE_URL=postgresql://shiftboard:shiftboard123@localhost:5432/shiftboard
TEST_DATABASE_URL=postgresql://shiftboard:shiftboard123@localhost:5432/shiftboard_test

# Kafka (shared by all services)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=shift-events

# Notification Service
KAFKA_CONSUMER_GROUP=notification-group

# Worker Service
SCHEDULING_SERVICE_URL=http://localhost:8000
WORKER_INTERVAL_SECONDS=60
